{
  "manifest_version": 3,
  "name": "Lumafold",
  "version": "1.0.0",
  "description": "A minimal, powerful notes app with folders, panels, and rich text editing.",
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": ["storage", "tabs"],
  "commands": {
    "open-fullscreen": {
      "suggested_key": { "default": "Alt+Shift+N" },
      "description": "Open Lumafold in fullscreen tab"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
